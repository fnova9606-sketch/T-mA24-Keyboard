<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/light_keyboard_bg"
    android:paddingBottom="4dp">

    <!-- ══ Resize handle ════════════════════════════════════════════ -->
    <com.tma24.keyboard.ResizeHandle
        android:id="@+id/resize_handle"
        android:layout_width="match_parent"
        android:layout_height="12dp"/>

    <!-- ══ Row 0 — Editing toolbar ══════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:background="@color/light_toolbar_bg">

        <Button
            android:tag="key:SELECT_ALL"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="@string/label_select_all"
            android:textSize="10sp"
            android:textColor="@color/light_toolbar_text"
            android:background="@color/transparent"
            android:gravity="center"
            style="?android:attr/borderlessButtonStyle"/>

        <View android:layout_width="1dp" android:layout_height="match_parent"
            android:background="#33FFFFFF"/>

        <Button
            android:tag="key:CUT"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="@string/label_cut"
            android:textSize="10sp"
            android:textColor="@color/light_toolbar_text"
            android:background="@color/transparent"
            android:gravity="center"
            style="?android:attr/borderlessButtonStyle"/>

        <View android:layout_width="1dp" android:layout_height="match_parent"
            android:background="#33FFFFFF"/>

        <Button
            android:tag="key:COPY"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="@string/label_copy"
            android:textSize="10sp"
            android:textColor="@color/light_toolbar_text"
            android:background="@color/transparent"
            android:gravity="center"
            style="?android:attr/borderlessButtonStyle"/>

        <View android:layout_width="1dp" android:layout_height="match_parent"
            android:background="#33FFFFFF"/>

        <Button
            android:tag="key:PASTE"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="@string/label_paste"
            android:textSize="10sp"
            android:textColor="@color/light_toolbar_text"
            android:background="@color/transparent"
            android:gravity="center"
            style="?android:attr/borderlessButtonStyle"/>

        <View android:layout_width="1dp" android:layout_height="match_parent"
            android:background="#33FFFFFF"/>

        <Button
            android:tag="key:ARROW_L"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="@string/label_arrow_left"
            android:textSize="14sp"
            android:textColor="@color/light_toolbar_text"
            android:background="@color/transparent"
            android:gravity="center"
            style="?android:attr/borderlessButtonStyle"/>

        <Button
            android:tag="key:ARROW_R"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="@string/label_arrow_right"
            android:textSize="14sp"
            android:textColor="@color/light_toolbar_text"
            android:background="@color/transparent"
            android:gravity="center"
            style="?android:attr/borderlessButtonStyle"/>

        <Button
            android:tag="key:EMOJI"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="😊"
            android:textSize="16sp"
            android:background="@color/transparent"
            android:gravity="center"
            style="?android:attr/borderlessButtonStyle"/>

    </LinearLayout>

    <!-- ══ Row 1 — Q W E R T Y U I O P ══════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="6dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <Button android:tag="key:q" android:layout_width="0dp"
            android:layout_height="48dp" android:layout_weight="1"
            android:text="Q" android:textSize="17sp"
            style="@style/KeyStyle.Character"/>
        <Button android:tag="key:w" android:layout_width="0dp"
            android:layout_height="48dp" android:layout_weight="1"
            android:text="W" android:textSize="17sp"
            style="@style/KeyStyle.Character"/>
        <Button android:tag="key:e" android:layout_width="0dp"
            android:layout_height="48dp" android:layout_weight="1"
            android:text="E" android:textSize="17sp"
            style="@style/KeyStyle.Character"/>
        <Button android:tag="key:r" android:layout_width="0dp"
            android:layout_height="48dp" android:layout_weight="1"
            android:text="R" android:textSize="17sp"
            style="@style/KeyStyle.Character"/>
        <Button android:tag="key:t" android:layout_width="0dp"
            android:layout_height="48dp" android:layout_weight="1"
            android:text="T" android:textSize="17sp"
            style="@style/KeyStyle.Character"/>
        <Button android:tag="key:y" android:layout_width="0dp"
            android:layout_height="48dp" android:layout_weight="1"
            android:text="Y" android:textSize="17sp"
            style="@style/KeyStyle.Character"/>
        <Button android:tag="key:u" android:layout_width="0dp"
            android:layout_height="48dp" android:layout_weight="1"
            android:text="U" android:textSize="17sp"
            style="@style/KeyStyle.Character"/>
        <Button android:tag="key:i" android:layout_width="0dp"
            android:layout_height="48dp" android:layout_weight="1"
            android:text="I" android:textSize="17sp"
            style="@style/KeyStyle.Character"/>
        <Button android:tag="key:o" android:layout_width="0dp"
            android:layout_height="48dp" android:layout_weight="1"
            android:text="O" android:textSize="17sp"
            style="@style/KeyStyle.Character"/>
        <Button android:tag="key:p" android:layout_width="0dp"
            android:layout_height="48dp" android:layout_weight="1"
            android:text="P" android:textSize="17sp"
            style="@style/KeyStyle.Character"/>

    </LinearLayout>

    <!-- ══ Row 2 — A S D F G H J K L ════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:paddingStart="18dp"
        android:paddingEnd="18dp">

        <Button android:tag="key:a" android:layout_width="0dp"
            android:layout_height="48dp" android:layout_weight="1"
            android:text="A" android:textSize="17sp"
            style="@style/KeyStyle.Character"/>
        <Button android:tag="key:s" android:layout_width="0dp"
            android:layout_height="48dp" android:layout_weight="1"
            android:text="S" android:textSize="17sp"
            style="@style/KeyStyle.Character"/>
        <Button android:tag="key:d" android:layout_width="0dp"
            android:layout_height="48dp" android:layout_weight="1"
            android:text="D" android:textSize="17sp"
            style="@style/KeyStyle.Character"/>
        <Button android:tag="key:f" android:layout_width="0dp"
            android:layout_height="48dp" android:layout_weight="1"
            android:text="F" android:textSize="17sp"
            style="@style/KeyStyle.Character"/>
        <Button android:tag="key:g" android:layout_width="0dp"
            android:layout_height="48dp" android:layout_weight="1"
            android:text="G" android:textSize="17sp"
            style="@style/KeyStyle.Character"/>
        <Button android:tag="key:h" android:layout_width="0dp"
            android:layout_height="48dp" android:layout_weight="1"
            android:text="H" android:textSize="17sp"
            style="@style/KeyStyle.Character"/>
        <Button android:tag="key:j" android:layout_width="0dp"
            android:layout_height="48dp" android:layout_weight="1"
            android:text="J" android:textSize="17sp"
            style="@style/KeyStyle.Character"/>
        <Button android:tag="key:k" android:layout_width="0dp"
            android:layout_height="48dp" android:layout_weight="1"
            android:text="K" android:textSize="17sp"
            style="@style/KeyStyle.Character"/>
        <Button android:tag="key:l" android:layout_width="0dp"
            android:layout_height="48dp" android:layout_weight="1"
            android:text="L" android:textSize="17sp"
            style="@style/KeyStyle.Character"/>

    </LinearLayout>

    <!-- ══ Row 3 — ⇧  Z X C V B N M  ⌫ ══════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <Button
            android:tag="key:SHIFT"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1.5"
            android:text="@string/label_shift"
            android:textSize="18sp"
            style="@style/KeyStyle.Special"/>

        <Button android:tag="key:z" android:layout_width="0dp"
            android:layout_height="48dp" android:layout_weight="1"
            android:text="Z" android:textSize="17sp"
            style="@style/KeyStyle.Character"/>
        <Button android:tag="key:x" android:layout_width="0dp"
            android:layout_height="48dp" android:layout_weight="1"
            android:text="X" android:textSize="17sp"
            style="@style/KeyStyle.Character"/>
        <Button android:tag="key:c" android:layout_width="0dp"
            android:layout_height="48dp" android:layout_weight="1"
            android:text="C" android:textSize="17sp"
            style="@style/KeyStyle.Character"/>
        <Button android:tag="key:v" android:layout_width="0dp"
            android:layout_height="48dp" android:layout_weight="1"
            android:text="V" android:textSize="17sp"
            style="@style/KeyStyle.Character"/>
        <Button android:tag="key:b" android:layout_width="0dp"
            android:layout_height="48dp" android:layout_weight="1"
            android:text="B" android:textSize="17sp"
            style="@style/KeyStyle.Character"/>
        <Button android:tag="key:n" android:layout_width="0dp"
            android:layout_height="48dp" android:layout_weight="1"
            android:text="N" android:textSize="17sp"
            style="@style/KeyStyle.Character"/>
        <Button android:tag="key:m" android:layout_width="0dp"
            android:layout_height="48dp" android:layout_weight="1"
            android:text="M" android:textSize="17sp"
            style="@style/KeyStyle.Character"/>

        <Button
            android:tag="key:BACKSPACE"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1.5"
            android:text="@string/label_backspace"
            android:textSize="18sp"
            style="@style/KeyStyle.Special"/>

    </LinearLayout>

    <!-- ══ Row 4 — Mode | , | SPACE | . | ↵ ═════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <Button
            android:tag="key:MODE_CODE"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1.4"
            android:text="@string/label_mode_code"
            android:textSize="11sp"
            style="@style/KeyStyle.Mode"/>

        <Button
            android:tag="key:MODE_AM"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1.2"
            android:text="@string/label_mode_am"
            android:textSize="13sp"
            style="@style/KeyStyle.Mode"/>

        <Button
            android:tag="key:,"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="0.8"
            android:text=","
            android:textSize="17sp"
            style="@style/KeyStyle.Character"/>

        <Button
            android:tag="key:SPACE"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="4"
            android:text="@string/label_space"
            android:textSize="13sp"
            style="@style/KeyStyle.Action"/>

        <Button
            android:tag="key:."
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="0.8"
            android:text="."
            android:textSize="17sp"
            style="@style/KeyStyle.Character"/>

        <Button
            android:tag="key:ENTER"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1.8"
            android:text="@string/label_return"
            android:textSize="20sp"
            style="@style/KeyStyle.Action"/>

    </LinearLayout>

</LinearLayout>