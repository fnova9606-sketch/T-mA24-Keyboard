<?xml version="1.0" encoding="utf-8"?>
<!--
    This file registers the keyboard's input method subtypes with Android.
    Each subtype appears in the system language switcher.
    The keyboard icon in the navigation bar cycles through these.
-->
<input-method xmlns:android="http://schemas.android.com/apk/res/android"
    android:settingsActivity="com.tma24.keyboard.SettingsActivity"
    android:isDefault="false">

    <!-- English QWERTY subtype -->
    <subtype
        android:label="@string/subtype_english"
        android:imeSubtypeLocale="en_US"
        android:imeSubtypeMode="keyboard"
        android:imeSubtypeExtraValue="KeyboardLayoutSet=qwerty,AsciiCapable,EmojiCapable"
        android:isAsciiCapable="true" />

    <!-- Amharic (Ethiopic) subtype -->
    <subtype
        android:label="@string/subtype_amharic"
        android:imeSubtypeLocale="am_ET"
        android:imeSubtypeMode="keyboard"
        android:imeSubtypeExtraValue="KeyboardLayoutSet=amharic,EmojiCapable"
        android:isAsciiCapable="false" />

    <!-- Coding / Developer subtype -->
    <subtype
        android:label="@string/subtype_coding"
        android:imeSubtypeLocale="en_US"
        android:imeSubtypeMode="keyboard"
        android:imeSubtypeExtraValue="KeyboardLayoutSet=coding,AsciiCapable"
        android:isAsciiCapable="true" />

</input-method>