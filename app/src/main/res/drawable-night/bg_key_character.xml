<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Pressed -->
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/dark_key_bg_pressed"/>
                    <corners android:radius="6dp"/>
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- Normal -->
    <item>
        <layer-list>
            <item android:top="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="#050A10"/>
                    <corners android:radius="6dp"/>
                </shape>
            </item>
            <item android:bottom="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/dark_key_bg"/>
                    <corners android:radius="6dp"/>
                    <stroke
                        android:width="0.5dp"
                        android:color="@color/dark_key_border"/>
                </shape>
            </item>
        </layer-list>
    </item>

</selector>