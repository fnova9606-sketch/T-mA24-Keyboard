<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Pressed -->
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/brass_light"/>
                    <corners android:radius="8dp"/>
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- Normal — brass/gold for dark keyboard -->
    <item>
        <layer-list>
            <item android:top="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="#8B6514"/>
                    <corners android:radius="8dp"/>
                </shape>
            </item>
            <item android:bottom="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/brass"/>
                    <corners android:radius="8dp"/>
                </shape>
            </item>
        </layer-list>
    </item>

</selector>