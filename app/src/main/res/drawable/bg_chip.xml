<?xml version="1.0" encoding="utf-8"?>
<!--
    Background for clipboard suggestion chips in the strip bar.
    White rounded pill with ledger-blue border.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Pressed -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/ledger_blue"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>

    <!-- Normal -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/light_chip_bg"/>
            <corners android:radius="16dp"/>
            <stroke
                android:width="1dp"
                android:color="@color/light_chip_border"/>
        </shape>
    </item>

</selector>