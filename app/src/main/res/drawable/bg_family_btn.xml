<?xml version="1.0" encoding="utf-8"?>
<!--
    Background for the 7 Amharic family order buttons in the candidates bar.
    Deep blue surface — they sit on the dark blue strip so contrast is clear.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Pressed — brass highlight to confirm selection -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/brass"/>
            <corners android:radius="6dp"/>
        </shape>
    </item>

    <!-- Normal -->
    <item>
        <layer-list>
            <item android:top="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/ledger_blue_dark"/>
                    <corners android:radius="6dp"/>
                </shape>
            </item>
            <item android:bottom="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/family_btn_bg_light"/>
                    <corners android:radius="6dp"/>
                </shape>
            </item>
        </layer-list>
    </item>

</selector>