<?xml version="1.0" encoding="utf-8"?>
<!--
    Pill-shaped background for mode-switch buttons (EN / አማ / </>).
    Uses a rounded rectangle with high corner radius to create pill shape.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Pressed -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/ledger_blue_light"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>

    <!-- Normal -->
    <item>
        <layer-list>
            <item android:top="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/ledger_blue_dark"/>
                    <corners android:radius="20dp"/>
                </shape>
            </item>
            <item android:bottom="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/ledger_blue"/>
                    <corners android:radius="20dp"/>
                </shape>
            </item>
        </layer-list>
    </item>

</selector>