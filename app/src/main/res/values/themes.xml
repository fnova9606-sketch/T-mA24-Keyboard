<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Base application theme.
        The keyboard view itself is drawn manually (not via Material theme),
        but the SettingsActivity and any dialogs use this.
    -->
    <style name="Theme.TMA24Keyboard" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/ledger_blue</item>
        <item name="colorPrimaryVariant">@color/ledger_blue_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/brass</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/parchment</item>
        <item name="android:windowBackground">@color/parchment</item>
        <item name="android:statusBarColor">@color/ledger_blue_dark</item>
        <item name="android:navigationBarColor">@color/ledger_blue_dark</item>
    </style>

    <!-- Settings Activity inherits base -->
    <style name="Theme.TMA24Keyboard.Settings" parent="Theme.TMA24Keyboard">
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
    </style>

</resources>
