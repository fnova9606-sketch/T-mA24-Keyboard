<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ═══════════════════════════════════════════════════════════════
         APPLICATION THEMES
         ═══════════════════════════════════════════════════════════════ -->

    <style name="Theme.TMA24Keyboard" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/ledger_blue</item>
        <item name="colorPrimaryVariant">@color/ledger_blue_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/brass</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/parchment</item>
        <item name="android:windowBackground">@color/parchment</item>
        <item name="android:statusBarColor">@color/ledger_blue_dark</item>
        <item name="android:navigationBarColor">@color/ledger_blue_dark</item>
    </style>

    <style name="Theme.TMA24Keyboard.Settings" parent="Theme.TMA24Keyboard">
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════════
         BASE PARENT STYLES
         Must exist before any dot-notation child can inherit from them.
         ═══════════════════════════════════════════════════════════════ -->

    <style name="KeyStyle">
        <item name="android:layout_margin">2dp</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:gravity">center</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:textColor">@color/light_key_text</item>
        <item name="android:background">@drawable/bg_key_character</item>
    </style>

    <style name="FamilyStyle">
        <item name="android:layout_margin">2dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:gravity">center</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:textColor">@color/family_btn_text_light</item>
        <item name="android:background">@drawable/bg_family_btn</item>
        <item name="android:textSize">24sp</item>
        <item name="android:fontFamily">serif</item>
    </style>

    <style name="ClipStyle">
        <item name="android:layout_margin">3dp</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:paddingEnd">10dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:textColor">@color/light_chip_text</item>
        <item name="android:background">@drawable/bg_chip</item>
        <item name="android:textSize">13sp</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════════
         CHILD KEY STYLES
         ═══════════════════════════════════════════════════════════════ -->

    <style name="KeyStyle.Character" parent="KeyStyle">
        <item name="android:layout_margin">2dp</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:gravity">center</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:background">@drawable/bg_key_character</item>
        <item name="android:textColor">@color/light_key_text</item>
    </style>

    <style name="KeyStyle.Special" parent="KeyStyle">
        <item name="android:layout_margin">2dp</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:gravity">center</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">@drawable/bg_key_special</item>
        <item name="android:textColor">@color/light_key_text</item>
    </style>

    <style name="KeyStyle.Action" parent="KeyStyle">
        <item name="android:layout_margin">2dp</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:gravity">center</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">@drawable/bg_key_action</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="KeyStyle.Mode" parent="KeyStyle">
        <item name="android:layout_margin">2dp</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:paddingEnd">10dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">@drawable/bg_key_mode</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="KeyStyle.Arrow" parent="KeyStyle">
        <item name="android:layout_margin">2dp</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:gravity">center</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">@drawable/bg_key_action</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="KeyStyle.Modifier" parent="KeyStyle">
        <item name="android:layout_margin">2dp</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:gravity">center</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">@drawable/bg_key_special</item>
        <item name="android:textColor">@color/light_key_text</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════════
         CHILD CLIP AND FAMILY STYLES
         ═══════════════════════════════════════════════════════════════ -->

    <style name="ClipStyle.Chip" parent="ClipStyle">
        <item name="android:layout_margin">3dp</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:paddingEnd">10dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:maxWidth">160dp</item>
        <item name="android:singleLine">true</item>
        <item name="android:ellipsize">end</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">@drawable/bg_chip</item>
        <item name="android:textColor">@color/light_chip_text</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="FamilyStyle.Button" parent="FamilyStyle">
        <item name="android:layout_margin">2dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:gravity">center</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">@drawable/bg_family_btn</item>
        <item name="android:textColor">@color/family_btn_text_light</item>
        <item name="android:textSize">24sp</item>
        <item name="android:fontFamily">serif</item>
    </style>

</resources>
