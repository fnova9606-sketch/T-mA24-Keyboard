<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.tma24.keyboard">

    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.TMA24Keyboard"
        android:hardwareAccelerated="true"
        android:extractNativeLibs="true"
        tools:replace="android:allowBackup,android:icon,android:label,android:supportsRtl,android:theme,android:hardwareAccelerated,android:extractNativeLibs"
        tools:ignore="GoogleAppIndexingWarning">

        <!-- Remove phantom MainActivity injected by library deps -->
        <activity
            android:name="com.tma24.keyboard.MainActivity"
            tools:node="remove" />

        <!-- Remove misclassified emoji2 initializer activity node -->
        <activity
            android:name="androidx.emoji2.text.EmojiCompatInitializer"
            tools:node="remove" />

        <!--
            Override the androidx.startup InitializationProvider that is
            injected transitively by lifecycle-runtime-ktx and emoji2.
            We disable automatic EmojiCompat and Lifecycle initialisation
            because the keyboard service manages its own lifecycle and does
            not need App Startup to run. Setting android:exported="false"
            and tools:node="merge" ensures our declaration wins and the
            provider is never exposed externally.
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                tools:node="remove" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                tools:node="remove" />
            <meta-data
                android:name="androidx.profileinstaller.ProfileInstallerInitializer"
                tools:node="remove" />
        </provider>

        <!--
            TMA24InputMethodService — the core IME service.
            android:exported="true" is mandatory for any service that
            carries an intent-filter on targetSdk 31+. The system
            binds to this service via android.view.InputMethod.
            android:permission restricts binding to the system only.
        -->
        <service
            android:name=".TMA24InputMethodService"
            android:label="@string/ime_name"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:exported="true">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>

        <!--
            SettingsActivity — launcher entry point and IME settings target.
            android:exported="true" is mandatory because this activity
            carries an intent-filter and must be reachable by the system
            keyboard settings screen on targetSdk 31+.
        -->
        <activity
            android:name=".SettingsActivity"
            android:label="@string/settings_title"
            android:exported="true"
            android:theme="@style/Theme.TMA24Keyboard.Settings">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
